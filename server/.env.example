# Required in production
JWT_SECRET=change-this-to-a-long-random-string

# Frontend origin(s) allowed by CORS — exact scheme + host (+ port in dev). Comma-separated for several URLs.
# Example: https://app.alvinyeaboah.com,http://localhost:5173
CLIENT_URL=https://your-frontend.up.railway.app

# Port (Railway sets this automatically)
# PORT=3001
